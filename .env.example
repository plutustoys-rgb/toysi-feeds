TOYSI_API_KEY=your_toysi_api_key_here
# auth_user для order_create API (toysi.ua/contact_info/?api=info) — auth_key = TOYSI_API_KEY вище
TOYSI_AUTH_USER=your_toysi_auth_user_here

# Безкоштовний ключ Нової Пошти (novaposhta.ua -> особистий кабінет -> Налаштування -> API)
NP_API_KEY=your_nova_poshta_api_key_here

# З'являться після реєстрації/модерації магазину
# Токен створюється в кабінеті Prom: Налаштування -> Управління API-токенами.
# orders_watcher.py/reconcile_revenue.py потребують лише "Замовлення та
# повідомлення". prom_catalog_sync.py додатково потребує "Продукти та групи"
# = "Читання та запис" (без цього /products/list і /products/edit_by_external_id
# повертають 403 Forbidden — перевірено 2026-07-10 з токеном, що мав лише
# доступ до замовлень).
PROM_API_KEY=your_prom_api_key_here

# ВИПРАВЛЕНО (2026-07-16): попереднє припущення "Rozetka НЕ підтримує
# окремий scoped API-ключ" виявилось хибним — є (Налаштування -> Безпека
# API -> Токени API, з явними ролями на кшталт "Контент-менеджер,
# Менеджер з обробки замовлень"), і саме він, ймовірно, потрібен для
# доступу до /orders/search, /v1/balances (логін-пароль повертав
# access_denied/code=1010 на ці ендпоінти, попри успішний вхід).
# ROZETKA_API_TOKEN — пріоритетний шлях у rozetka_client.py, якщо заданий.
# Власниця вводить значення напряму сюди, не через чат/агента.
ROZETKA_API_TOKEN=your_rozetka_api_token_here

# Фолбек, якщо ROZETKA_API_TOKEN ще не додано — логін/пароль Особистого
# кабінету продавця (rozetka_client.py, POST /sites), токен живе 24 год
# за активного використання. ROZETKA_API_KEY (стара змінна) більше ніде
# в коді не використовується.
ROZETKA_USERNAME=your_rozetka_seller_cabinet_login_here
ROZETKA_PASSWORD=your_rozetka_seller_cabinet_password_here

# Посилання на YML-експорт з кабінету RoyalToys ("Конструктор YML") — це
# секрет (дає доступ до оптового прайсу), не публікувати відкрито
ROYALTOYS_YML_URL=your_royaltoys_yml_export_url_here

# Приват24 для бізнесу -> Каталог послуг -> Інтеграція (Автоклієнт) — налаштовується вручну власником
PRIVAT_AUTOCLIENT_ID=your_privat_autoclient_id_here
PRIVAT_AUTOCLIENT_TOKEN=your_privat_autoclient_token_here
PRIVAT_IBAN=UA000000000000000000000000000

# Claude API — генерація/класифікація відповідей у prom_chat_bot.py.
# СТАН НА 2026-07-11: баланс вичерпано, поповнення свідомо відкладено
# власником. Без цього ключа бот не падає — кожне повідомлення просто
# ескалюється в Telegram (див. classify_and_respond у prom_chat_bot.py).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Бот PlutusToysBot — сповіщення власнику через telegram_notify.py
# (використовується в кількох скриптах: daily_report.py, order_router.py,
# service_watchdog.py, deadline_reminder.py, telegram_outbox_processor.py,
# run_all.py — не тримаємо тут вичерпний список, щоб не застарів; шукай
# send_telegram_message у коді). Токен від @BotFather, chat_id — власний
# Telegram chat_id власника (через getUpdates)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
