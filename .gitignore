.env

__pycache__/
*.pyc

# Локальний кеш каталогу Toysi (десятки МБ, генерується скриптами наново)
toysi_catalog_cache.json

# Локальний стан конкурентного ціноутворення (не для публічного репо)
competitor_pricing_checkpoint.json
pricing_results.csv
pricing_results_v1_legacy_backup.csv
pricing_results_pre_migration_backup.csv
price_corrections.csv

# Дебаг/скретч-файли
debug_page.html
debug_screenshot.png
scratch_search.html
scratch_product.html

# Локальна БД замовлень (runtime-стан, не для git)
orders.db
prom_chat.db

# PDF-етикетки Укрпошти — персональні дані клієнтів (ім'я/адреса/телефон)
ukrposhta_stickers/

# Runtime-стан service_watchdog.py (OK/ALARM по кожному сервісу)
watchdog_state.json

# Runtime-стан і звіти prom_catalog_auditor.py (генеруються наново на VPS,
# не для git — reports/ містить щоденні звіти, state.json — трекінг "перша
# поява проблеми" для порогу 24 год)
prom_catalog_audit_state.json
reports/

# Runtime-стан мосту prom_competitor_pricer.py (пише) <-> generate_prom_feed.py
# (читає) — {external_id: {price, timestamp}} для щойно застосованих
# конкурентних цін, плюс _meta.last_full_run для гейту "не частіше ~20 год".
# Мігровано на GitHub Actions 2026-07-13, ПОВЕРНУТО на VPS-таймер
# 2026-07-24 (6.2-6.3 год живого пошуку конкурента на 6000 SKU перевищує
# 6-годинну стелю GH Actions job'у): prom_competitor_pricer.py тепер
# виконується systemd-таймером на VPS, читає/пише цей файл локально між
# прогонами (без CI-обмежень), публікує його в окрему гілку
# pricer-state-data одразу після кожного реального прогону
# (publish_pricer_state.sh). update-feeds.yml (GH Actions) лише читає
# найсвіжішу опубліковану копію звідти на старті job'у для решти
# генерації фідів (EVA/ALLO/Google дзеркалять ціну Prom) і republish'ить
# її в feed-data наприкінці (застаріла ~4 год копія для сумісності з
# будь-ким, хто досі читає саме звідти).
prom_competitor_price_state.json

# Стислий людський підсумок останнього прогону репрайсера (не для коду) —
# НЕ публікується в feed-data (та гілка вже публічна, а тут стратегічні
# лічильники репрайсера — той самий тип сигналу про ціноутворення, який
# раніше вирішили не публікувати відкрито). Замість цього — приватний
# GitHub Actions artifact (update-feeds.yml), доступний лише через
# автентифікований `gh run download`; синхронізація в спільну Windows-теку
# PlutusToys_avtonomiya — вручну, коли активна Claude-сесія (той самий
# підхід, що й prom_catalog_audit_summary.md там).
prom_competitor_pricer_summary.md

# Runtime-стан одноразового скану повного каталогу (full_catalog_competitor_
# scan.py, 2026-07-13) — {sku: {cost, category_name, competitor_price,
# competitor_score, margin_pct, price_category}} для ~17 000 eligible SKU,
# готує дані для побудови нового топ-1000. Round-trip'иться через ОКРЕМУ
# гілку full-catalog-scan-data (full-catalog-scan.yml) — НЕ feed-data (та
# гілка публічна й force-push на неї замінив би live-фіди/стан репрайсера).
full_catalog_scan_state.json

# Rozetka-only стан членства для grace-періоду тимчасово відсутніх товарів
# (2026-07-16, root-cause SKU 299318/299320/299321/249158) — суто runtime,
# перебудовується щоразу з живих даних Toysi, не для git.
rozetka_feed_membership_state.json

# Лічильник "застряг N прогонів" для SKU, які Prom API мовчки/явно
# відмовляється видаляти (2026-07-21, findings_log.md
# "prom-delete-still-rejected-for-specific-sku") — суто runtime-трекінг
# послідовних невдалих спроб prom_catalog_sync.py, не для git.
prom_catalog_sync_stuck_state.json

# КОДВ-журнал (daily_report.py, 2026-07-20) — накопичувальний, живе на
# VPS, публікується publish_kodv_ledger.sh в ОКРЕМУ гілку kodv-ledger-data
# (НЕ feed-data — той самий принцип ізоляції, що й full_catalog_scan_state.json
# вище: два незалежні force-push-публікатори на ОДНУ гілку затирали б один
# одного; тут іще важливіше, бо це фінансові дані, які force-push взагалі
# не повинен зачіпати — publish_kodv_ledger.sh комітить з реальною історією,
# не force-push).
kodv_ledger.jsonl

# Запобіжник: файл з паролями не повинен потрапити в git навіть випадково
паролі.txt

# Згенеровані фіди (десятки МБ кожен) — публікуються тільки в гілку feed-data
# (force-push, без історії), у master/main їм не місце
feeds/*.xml

# VPS-доступ (пароль root) — лише локально, ніколи в git
vps_access.local.md

# Кеш self-match товар<->Prom-лістинг (generate_google_feed.py пише,
# generate_rozetka_feed.py лише читає) — генерується наново, не для git
own_product_links_cache.json

# Кеш реальної Prom-категорії товару (generate_google_feed.py пише,
# prom_competitor_pricer.py/full_catalog_competitor_scan.py читають) —
# той самий клас файлу, що й own_product_links_cache.json вище
prom_category_cache.json

# Внутрішньопрогонний кеш повного списку товарів Prom (TTL 1 година —
# generate_google_feed.py пише, generate_meta_feed.py/generate_bing_feed.py
# читають, щоб не робити той самий важкий /groups/list-запит тричі в
# одному прогоні update-feeds.yml, аудит PR #109)
prom_products_raw_cache.json

# Вручну курований override-опис для 93 SKU з мінімальним "Бренд+Країна"
# описом від Toysi (Vis-9) — реальний контент, який пише Cowork/власниця
# напряму на VPS, не для git (той самий клас локальних даних, що й
# rozetka_category_rz_id_map.json нижче — специфічний для акаунту вміст,
# не код)
description_overrides.json

# Довідник rz_id категорій Rozetka, вручну експортований власницею з
# власного кабінету (Управління товарами -> Довідники) — локальні,
# специфічні для акаунту дані, не для git (той самий клас файлу, що й
# інші локальні кеші/довідники вище)
rozetka_category_rz_id_map.json
